{
    "name": "rlvendramini/url-parser",
    "description": "A URL parser to edit and rebuild URL strings",
    "type": "library",
    "autoload": {
        "classmap": [
            "lib/"
        ]
    },
    "require-dev": {
        "php": ">=8.4",
        "phpunit/phpunit": "^12.3.15",
        "friendsofphp/php-cs-fixer": "^3.88.2",
        "phpstan/phpstan": "^2.1.30"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Renan Luiz Vendramini",
            "email": "renanlvendramini@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "scripts": {
        "test": "./vendor/bin/phpunit --testdox tests",
        "fix": "./vendor/bin/php-cs-fixer fix",
        "lint": "./vendor/bin/phpstan analyse"
    }
}
